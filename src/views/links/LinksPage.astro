---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";
import { getLangFromUrl, toLocalizedPath, useTranslations } from "@/i18n/utils";

if (!SITE.showLinks) {
  return Astro.redirect(toLocalizedPath(getLangFromUrl(Astro.url), "/404"));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const [entry] = await getCollection("links");

if (!entry) {
  throw new Error("Links collection is empty. Add src/data/links/index.md.");
}

const { Content } = await render(entry);
const links = entry.data.links;
---

<Layout
  title={`${t("links.title")} | ${SITE.title}`}
  description={t("links.description")}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12">
    <div class="links-hero" data-links-hero>
      <div class="aurora-orb aurora-orb-1"></div>
      <div class="aurora-orb aurora-orb-2"></div>
      <div class="aurora-mouse" data-links-mouse></div>
      <div class="relative z-10">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          <span class="glow-text">{t("links.title")}</span>
        </h1>
        <p class="mt-3 max-w-2xl text-foreground/70 italic">
          {t("links.description")}
        </p>
        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="hero-badge">{links.length} {t("links.count")}</span>
        </div>
      </div>
    </div>

    {
      entry.body && (
        <section class="app-prose mb-10 max-w-app prose-img:border-0">
          <Content />
        </section>
      )
    }

    {
      links.length === 0 ? (
        <p class="mt-12 text-center text-foreground/50 italic">
          {t("links.empty")}
        </p>
      ) : (
        <ul class="links-grid" role="list">
          {links.map(link => (
            <li>
              <a
                class="link-card group"
                href={link.url}
                target="_blank"
                rel="noopener noreferrer">
                <div class="link-card-glow" />
                <div class="link-card-inner">
                  <img
                    src={link.avatar}
                    alt={`${link.name} avatar`}
                    class="link-avatar"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="link-copy">
                    <div class="link-topline">
                      <h2 class="link-name">{link.name}</h2>
                    </div>
                    <p class="link-description">{link.description}</p>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  let linksCleanup: AbortController | null = null;

  document.addEventListener("astro:page-load", () => {
    if (linksCleanup) linksCleanup.abort();
    linksCleanup = new AbortController();
    const { signal } = linksCleanup;

    const hero = document.querySelector(
      "[data-links-hero]"
    ) as HTMLElement | null;
    const heroMouse = document.querySelector(
      "[data-links-mouse]"
    ) as HTMLElement | null;

    if (hero && heroMouse) {
      hero.addEventListener(
        "mousemove",
        e => {
          requestAnimationFrame(() => {
            const rect = hero.getBoundingClientRect();
            heroMouse.style.setProperty("--mx", `${e.clientX - rect.left}px`);
            heroMouse.style.setProperty("--my", `${e.clientY - rect.top}px`);
            heroMouse.style.opacity = "1";
          });
        },
        { signal }
      );

      hero.addEventListener(
        "mouseleave",
        () => {
          heroMouse.style.opacity = "0";
        },
        { signal }
      );
    }
  });
</script>

<style>
  .links-hero {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    padding: 2.5rem 2rem;
    margin-bottom: 2.5rem;
    background: color-mix(
      in srgb,
      var(--color-foreground) 3%,
      var(--color-background)
    );
    border: 1px solid color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  @media (min-width: 640px) {
    .links-hero {
      padding: 3rem 3rem;
    }
  }

  .aurora-orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(55px);
    pointer-events: none;
  }

  .aurora-orb-1 {
    top: -4rem;
    left: -2rem;
    width: 16rem;
    height: 16rem;
    background: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .aurora-orb-2 {
    right: -2rem;
    bottom: -5rem;
    width: 18rem;
    height: 18rem;
    background: color-mix(in srgb, var(--color-border) 30%, transparent);
  }

  .aurora-mouse {
    position: absolute;
    width: 350px;
    height: 350px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-accent) 18%, transparent),
      color-mix(in srgb, var(--color-border) 8%, transparent) 40%,
      transparent 70%
    );
    filter: blur(50px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
    transform: translate(
      calc(var(--mx, 0px) - 175px),
      calc(var(--my, 0px) - 175px)
    );
    will-change: transform;
    z-index: 1;
  }

  .glow-text {
    background: linear-gradient(
      135deg,
      var(--color-foreground),
      var(--color-accent)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(
      0 0 25px color-mix(in srgb, var(--color-accent) 25%, transparent)
    );
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    backdrop-filter: blur(8px);
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1rem;
  }

  .link-card {
    position: relative;
    display: block;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
    border-radius: 1.25rem;
    background: color-mix(in srgb, var(--color-background) 92%, transparent);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .link-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.08);
  }

  .link-card-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-accent) 10%, transparent),
      transparent 55%
    );
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .group:hover .link-card-glow {
    opacity: 1;
  }

  .link-card-inner {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem;
    height: 110px;
    max-height: 110px;
  }

  .link-avatar {
    width: 4rem;
    height: 4rem;
    flex-shrink: 0;
    border: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
    border-radius: 100%;
    object-fit: cover;
    background: color-mix(in srgb, var(--color-muted) 65%, transparent);
  }

  .link-copy {
    min-width: 0;
    flex: 1;
  }

  .link-topline {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
  }

  .link-name {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .link-cta {
    flex-shrink: 0;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
  }

  .link-description {
    margin-top: 0.5rem;
    color: color-mix(in srgb, var(--color-foreground) 72%, transparent);
    line-height: 1.6;
  }

  .link-url {
    margin-top: 0.75rem;
    overflow: hidden;
    color: color-mix(in srgb, var(--color-foreground) 48%, transparent);
    font-family: var(--font-cascadia-code), monospace;
    font-size: 0.8rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (min-width: 1100px) {
    .links-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .link-card-inner {
      gap: 0.875rem;
      padding: 0.9rem;
    }

    .link-avatar {
      width: 3.25rem;
      height: 3.25rem;
      border-radius: 0.85rem;
    }

    .link-topline {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.3rem;
    }
  }
</style>
